@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcatap: <http://data.europa.eu/r5r/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix lcon: <http://www.w3.org/ns/locn#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix p-plan: <http://www.opmw.org/model/p-plan/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix pv: <https://piveau.eu/ns/voc#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix ssn-system: <http://www.w3.org/ns/ssn/systems/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

########################################################
# Manufacturer Shape
########################################################

pv:ManufacturerShape
    a sh:NodeShape ;
    sh:targetClass foaf:Organization, pv:CustomResource ;
    sh:name "Manufacturer"@en ;


    # Identifier
    sh:property [
        sh:path dct:identifier ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Each organization must have a unique identifier." 
    ] ;

    # Name
    sh:property [
        sh:path dct:title ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Each organization must have an official name." 
    ] ;

    # Description
    sh:property [
        sh:path dct:description ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A brief description of the organization and what it does." 
    ] ;

    # Category
    sh:property [
        sh:path dct:type ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:message "The type of product or service the manufacturer provides (e.g., GIS Software, Traffic Detection Hardware, etc.)." 
    ] ;

    # Location
    sh:property [
        sh:path     vcard:hasAddress ;
        sh:minCount 1 ; 
        sh:maxCount 1 ;
        sh:message  "Organization must have exactly one Postal Address." 
    ] ;

    # Website
    sh:property [
        sh:path foaf:homepage ;
        sh:nodeKind sh:BlankNodeOrIRI;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "The official website of the organization. Should be a valid URL." 
    ] ;

    # Linked Hardware or Software
    sh:property [
        sh:path     foaf:made ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:or (
            [ sh:class schema:SoftwareApplication ]
            [ sh:class ssn:System ]
        ) ;
        sh:minCount 1 ;
        sh:message  "If the organization makes software or hardware, link to the software or hardware here." 
    ] ;

    # Logo
    sh:property [
        sh:path foaf:depiction ;
        sh:nodeKind sh:BlankNodeOrIRI;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:message "The depiction (e.g., logo) of the organization. Should be a valid image URL." 
    ] ;

    # Catalog

    # Country

    # Catalog Record
    sh:property [
          sh:maxCount 1 ;
          sh:path dcat:catalogRecord 
    ] ;
    
    # Last modified
    # TODO: Can all of the modified properties be removed as this is stored in catalog_record.modified?
    sh:property [
        sh:node dcatap:DateOrDateTimeDataType_Shape ;
        sh:path        prov:generatedAtTime ;
        sh:minCount    0 ;
        sh:maxCount    1 ;
        sh:message     "The dateTime when this metadata was last modified." 
    ] ;

    # Resources
    sh:property [
        sh:path dct:references ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:minCount 0 ;
        sh:message "Links to any extra documentation regarding the organization." 
    ] .

pv:ManufacturerLinkShape
    a sh:NodeShape ;
    sh:name "ManufacturerLink"@en ;


    # Label
    sh:property [
        sh:path skos:prefLabel ;
        sh:maxCount 1 ;
        sh:message "The label of the organization." 
    ] .

dcatap:Vcard_Address_Shape
    a sh:NodeShape ;
    sh:name "VcardAddress"@en ;
    sh:property [
          sh:maxCount 1 ;
          sh:nodeKind sh:Literal ;
          sh:path vcard:street-address ;
          sh:severity sh:Violation
      ] ,
        [
          sh:maxCount 1 ;
          sh:nodeKind sh:Literal ;
          sh:path vcard:locality ;
          sh:severity sh:Violation
      ] ,
        [
          sh:maxCount 1 ;
          sh:nodeKind sh:Literal ;
          sh:path vcard:postal-code ;
          sh:severity sh:Violation
      ] ;
    sh:targetClass vcard:Address .
